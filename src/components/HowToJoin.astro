---
import { links } from "../data/site";
---

<section id="how-to-join" class="section bg-maroon text-white">
  <div class="container mx-auto max-w-5xl">
    <div class="max-w-2xl">
      <p class="section-eyebrow text-happy">How to join</p>
      <h2 class="section-heading text-white">Two small steps.</h2>
      <p class="mt-4 text-lg text-slate-100">
        No forms to print. No hoops to jump through. No commitment before your first visit.
      </p>
    </div>

    <ol class="mt-10 grid gap-5 md:grid-cols-2">
      <li class="rounded-2xl bg-white/10 p-6 ring-1 ring-white/15 backdrop-blur">
        <div class="flex items-center gap-3">
          <span class="flex h-10 w-10 items-center justify-center rounded-full bg-happy text-lg font-bold text-slate-900">1</span>
          <h3 class="font-display text-xl font-bold text-white">Fill out the Visit Club form</h3>
        </div>
        <p class="mt-4 text-slate-100">
          On the official Toastmasters directory, click the <strong class="text-happy">Visit Club</strong> button and tell us
          you&rsquo;re coming. Our VP Membership will be expecting you.
        </p>
        <a href={links.toastmastersDirectory.href} rel="noopener" target="_blank" class="btn-primary mt-5 bg-white !text-maroon hover:bg-happy hover:!text-slate-900">
          Open the directory page
          <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M7 17 17 7M7 7h10v10"/></svg>
        </a>
      </li>

      <li class="rounded-2xl bg-white/10 p-6 ring-1 ring-white/15 backdrop-blur">
        <div class="flex items-center gap-3">
          <span class="flex h-10 w-10 items-center justify-center rounded-full bg-happy text-lg font-bold text-slate-900">2</span>
          <h3 class="font-display text-xl font-bold text-white">Come along on a Wednesday</h3>
        </div>
        <p class="mt-4 text-slate-100">
          When you arrive, ask for the <strong class="text-happy">current VP of Membership</strong> or the <strong class="text-happy">Club President</strong>.
          They will walk you through the short application and answer anything you want to know. Totally free, totally no-pressure.
        </p>
      </li>
    </ol>

    <p class="mt-8 text-sm text-slate-200">
      Prefer to chat first? <a href={links.whatsappDirect.href} rel="noopener" target="_blank" class="underline hover:text-happy">Message us on WhatsApp</a> or
      <a href={links.whatsappGroup.href} rel="noopener" target="_blank" class="underline hover:text-happy">join our WhatsApp group</a> &mdash; introduce yourself; we love knowing who&rsquo;s new.
    </p>
  </div>
</section>
