---
import { Image } from "astro:assets";
import logo from "../assets/images/achievers_logo_564.png";
import { club, links, nav } from "../data/site";
---

<header class="sticky top-0 z-40 border-b border-slate-200/60 bg-[--color-paper]/90 backdrop-blur">
  <nav class="container mx-auto flex items-center justify-between gap-4 py-3">
    <a href="#top" class="flex items-center gap-3" aria-label={club.name}>
      <Image
        src={logo}
        alt="Marbella Achievers logo"
        width={44}
        height={44}
        class="h-11 w-11 rounded-md"
        loading="eager"
      />
      <span class="font-display text-base font-bold leading-tight text-slate-900 sm:text-lg">
        {club.shortName}
        <span class="block text-xs font-normal text-slate-500">Toastmasters Club</span>
      </span>
    </a>

    <ul class="hidden items-center gap-6 lg:flex">
      {
        nav.map((item) => (
          <li>
            <a
              href={item.href}
              class="text-sm font-semibold text-slate-700 transition-colors hover:text-maroon"
            >
              {item.label}
            </a>
          </li>
        ))
      }
    </ul>

    <a
      href={links.toastmastersDirectory.href}
      rel="noopener"
      target="_blank"
      class="hidden btn-primary sm:inline-flex"
    >
      Visit a meeting
    </a>

    <button
      type="button"
      class="inline-flex h-11 w-11 items-center justify-center rounded-md text-slate-700 hover:bg-slate-100 lg:hidden"
      aria-label="Toggle navigation menu"
      aria-expanded="false"
      data-nav-toggle
    >
      <svg
        class="h-6 w-6"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        viewBox="0 0 24 24"
        aria-hidden="true"
      >
        <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16"></path>
      </svg>
    </button>
  </nav>

  <div id="mobile-nav" class="hidden border-t border-slate-200 bg-white lg:hidden">
    <ul class="container mx-auto flex flex-col gap-1 py-3">
      {
        nav.map((item) => (
          <li>
            <a
              href={item.href}
              class="block rounded-md px-3 py-2 text-base font-semibold text-slate-700 hover:bg-slate-100 hover:text-maroon"
              data-nav-link
            >
              {item.label}
            </a>
          </li>
        ))
      }
      <li class="pt-2">
        <a
          href={links.toastmastersDirectory.href}
          rel="noopener"
          target="_blank"
          class="btn-primary w-full"
        >
          Visit a meeting
        </a>
      </li>
    </ul>
  </div>
</header>

<script>
  const toggle = document.querySelector<HTMLButtonElement>("[data-nav-toggle]");
  const menu = document.getElementById("mobile-nav");
  if (toggle && menu) {
    toggle.addEventListener("click", () => {
      const open = menu.classList.toggle("hidden");
      toggle.setAttribute("aria-expanded", (!open).toString());
    });
    menu.querySelectorAll<HTMLAnchorElement>("[data-nav-link]").forEach((a) => {
      a.addEventListener("click", () => {
        menu.classList.add("hidden");
        toggle.setAttribute("aria-expanded", "false");
      });
    });
  }
</script>
