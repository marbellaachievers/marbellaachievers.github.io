---
import { faqs } from "../data/site";

const faqJsonLd = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: faqs.map((f) => ({
    "@type": "Question",
    name: f.q,
    acceptedAnswer: { "@type": "Answer", text: f.a },
  })),
};
---

<section id="faq" class="section bg-[--color-paper]">
  <div class="container mx-auto max-w-4xl">
    <div class="max-w-2xl">
      <p class="section-eyebrow">Frequently asked</p>
      <h2 class="section-heading">Think you can&rsquo;t become a confident speaker?</h2>
      <p class="mt-4 text-lg text-slate-600">
        We&rsquo;ve heard that before. Here are the questions we hear most often &mdash; and the
        honest answers.
      </p>
    </div>

    <ul
      class="mt-10 divide-y divide-slate-200 rounded-2xl bg-white shadow-sm ring-1 ring-slate-100"
    >
      {
        faqs.map((f) => (
          <li>
            <details class="group px-6 py-5 open:bg-slate-50">
              <summary class="flex cursor-pointer list-none items-center justify-between gap-6">
                <span class="font-display text-lg font-bold text-slate-900">{f.q}</span>
                <svg
                  class="h-5 w-5 shrink-0 text-maroon transition-transform group-open:rotate-180"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  aria-hidden="true"
                >
                  <path d="m6 9 6 6 6-6" />
                </svg>
              </summary>
              <p class="mt-3 text-slate-600">{f.a}</p>
            </details>
          </li>
        ))
      }
    </ul>
  </div>

  <script type="application/ld+json" set:html={JSON.stringify(faqJsonLd)} />
</section>
