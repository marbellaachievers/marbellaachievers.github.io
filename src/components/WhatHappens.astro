---
import { Image } from "astro:assets";
import photo from "../assets/images/meeting-2026-04-15.jpg";
import { meetingFormat, meeting } from "../data/site";
---

<section id="what-happens" class="section bg-white">
  <div class="container mx-auto max-w-6xl">
    <div class="grid gap-12 lg:grid-cols-[1.1fr_1fr] lg:items-start">
      <div>
        <p class="section-eyebrow">What happens at a meeting</p>
        <h2 class="section-heading">An evening of practice, feedback, and friendship.</h2>
        <p class="mt-4 text-lg text-slate-600">
          Our meetings are structured, friendly, and entertaining &mdash; a bit like group practice and a bit like a variety show.
          Plan for {meeting.durationLabel.toLowerCase()}.
        </p>

        <ul class="mt-8 space-y-5">
          {meetingFormat.map((f, i) => (
            <li class="flex gap-4">
              <span class="flex h-9 w-9 flex-none items-center justify-center rounded-full bg-maroon text-sm font-bold text-white">
                {i + 1}
              </span>
              <div>
                <h3 class="font-display text-lg font-bold text-slate-900">{f.title}</h3>
                <p class="mt-1 text-slate-600">{f.body}</p>
              </div>
            </li>
          ))}
        </ul>

        <div class="mt-8 rounded-2xl border border-happy/60 bg-happy/20 p-5">
          <p class="text-slate-800">
            <strong>Guest policy:</strong> You will <em>never</em> be asked to speak on your first visit.
            Come, watch, and enjoy. When you are ready to try, we will be cheering you on.
          </p>
        </div>

        <p class="mt-6 text-slate-600">
          <strong class="text-slate-800">After the meeting:</strong> {meeting.postMeeting}
        </p>
      </div>

      <div>
        <div class="overflow-hidden rounded-2xl shadow-lg">
          <Image src={photo} alt="Members of the Marbella Achievers Toastmasters Club at a weekly meeting" widths={[480, 720, 960]} sizes="(min-width:1024px) 480px, 100vw" class="h-full w-full object-cover" />
        </div>
      </div>
    </div>
  </div>
</section>
