---
import { Image } from "astro:assets";
import logo from "../assets/images/achievers_logo_564.png";
import tmLogo from "../assets/images/toastmasters-logo@2x.png";
import SocialRow from "./SocialRow.astro";
import { club, links } from "../data/site";

const year = new Date().getFullYear();
---

<footer class="bg-cyan-700 text-slate-100">
  <div class="container mx-auto grid gap-10 py-14 md:grid-cols-[1.3fr_1fr_1fr]">
    <div>
      <div class="flex items-center gap-3">
        <Image src={logo} alt="" width={48} height={48} class="h-12 w-12 rounded-md bg-white p-1" />
        <div>
          <p class="font-display text-lg font-bold text-white">{club.shortName}</p>
          <p class="text-sm text-slate-300">{club.tagline}</p>
        </div>
      </div>
      <p class="mt-4 max-w-sm text-sm text-slate-300">
        Marbella's welcoming, English-speaking Toastmasters club. Guests always free on their first visit.
      </p>
    </div>

    <div>
      <h2 class="font-display text-sm font-bold uppercase tracking-wider text-happy">Follow us</h2>
      <div class="mt-4">
        <SocialRow variant="dark" />
      </div>
    </div>

    <div>
      <h2 class="font-display text-sm font-bold uppercase tracking-wider text-happy">Quick links</h2>
      <ul class="mt-4 space-y-2 text-sm">
        <li><a href={links.toastmastersDirectory.href} rel="noopener" target="_blank" class="hover:text-happy">Visit Club on Toastmasters.org</a></li>
        <li><a href={links.whatsappGroup.href} rel="noopener" target="_blank" class="hover:text-happy">WhatsApp group chat</a></li>
        <li><a href={links.whatsappDirect.href} rel="noopener" target="_blank" class="hover:text-happy">Message us on WhatsApp</a></li>
        <li><a href={links.github.href} rel="noopener" target="_blank" class="hover:text-happy">GitHub repository</a></li>
      </ul>
    </div>
  </div>

  <div class="border-t border-white/10">
    <div class="container mx-auto flex flex-col items-start gap-3 py-6 text-xs text-slate-300 sm:flex-row sm:items-center sm:justify-between">
      <p>&copy; {year} {club.name}. All rights reserved.</p>
      <div class="flex items-center gap-3 opacity-80">
        <Image src={tmLogo} alt="Toastmasters International" width={120} height={30} class="h-6 w-auto" />
        <span>Club #{club.clubNumber} &middot; Area {club.area}</span>
      </div>
    </div>
  </div>
</footer>
