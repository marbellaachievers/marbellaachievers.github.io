---
import { Image } from "astro:assets";
import heroImage from "../assets/images/meeting_2026-04-22.jpg";
import logo from "../assets/images/achievers_logo_564.png";
import { club, meeting, links } from "../data/site";
---

<section id="top" class="relative isolate overflow-hidden bg-cyan-700 text-white">
  <Image
    src={heroImage}
    alt=""
    class="absolute inset-0 -z-10 h-full w-full object-cover opacity-40"
    widths={[640, 960, 1440, 1920]}
    sizes="100vw"
    loading="eager"
    quality={70}
  />
  <div
    class="absolute inset-0 -z-10 bg-gradient-to-br from-cyan-800/85 via-cyan-700/75 to-maroon/70"
  >
  </div>

  <div
    class="container mx-auto flex min-h-[calc(100vh-4rem)] flex-col justify-center py-16 sm:py-20 lg:py-24"
  >
    <div class="max-w-3xl">
      <div
        class="mb-6 inline-flex items-center gap-3 rounded-full bg-white/10 px-4 py-1.5 text-sm font-semibold backdrop-blur"
      >
        <Image src={logo} alt="" width={28} height={28} class="h-7 w-7 rounded" />
        <span>{club.shortName} Toastmasters &middot; {club.city}</span>
      </div>

      <h1 class="font-display text-4xl font-extrabold leading-tight sm:text-5xl lg:text-6xl">
        Find your voice.<br />
        <span class="text-happy">{club.tagline}.</span>
      </h1>

      <p class="mt-6 max-w-2xl text-lg text-slate-100 sm:text-xl">
        Public speaking and leadership practice in a friendly, international, English-speaking club.
        Every {meeting.day} evening in Marbella.
        <strong class="font-semibold text-happy">Your first visit is always free.</strong>
      </p>

      <div class="mt-8 flex flex-col gap-3 sm:flex-row sm:items-center">
        <a
          href={links.toastmastersDirectory.href}
          rel="noopener"
          target="_blank"
          class="btn-primary"
        >
          Visit a meeting &mdash; it&rsquo;s free
        </a>
        <a href={links.whatsappDirect.href} rel="noopener" target="_blank" class="btn-whatsapp">
          <svg class="h-5 w-5" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path
              d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.693.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"
            ></path>
          </svg>
          Message us on WhatsApp
        </a>
      </div>

      <dl class="mt-10 grid max-w-xl grid-cols-3 gap-4 text-sm sm:gap-6 sm:text-base">
        <div>
          <dt class="text-slate-300">When</dt>
          <dd class="font-semibold">{meeting.day}s, {meeting.startTimeLabel}</dd>
        </div>
        <div>
          <dt class="text-slate-300">Where</dt>
          <dd class="font-semibold">{meeting.venueName}</dd>
        </div>
        <div>
          <dt class="text-slate-300">Cost</dt>
          <dd class="font-semibold">Guests &mdash; free</dd>
        </div>
      </dl>
    </div>
  </div>
</section>
